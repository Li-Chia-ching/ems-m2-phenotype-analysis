N_TOTAL = 1424

ANNO_BOX = dict(
    boxstyle='round,pad=0.5', facecolor=CLR['light_bg'], edgecolor=CLR['border'],
    alpha=0.92, linewidth=0.6,
)

# =============================================================================
# DATA LOADING
# =============================================================================

def load_data():
    m2 = pd.read_csv(DATA_DIR / "EMS_M2_Cleaned_1425plants.csv")
    s1 = pd.read_csv(DATA_DIR / "Updated_Supplementary_Table_S1.csv")
    s2 = pd.read_csv(DATA_DIR / "Updated_Supplementary_Table_S2.csv")
    dose = pd.read_csv(DATA_DIR / "EMS_M2_DoseResponse.csv")

    return {"m2": m2, "s1": s1, "s2": s2, "dose": dose}

# =============================================================================
# PHENOTYPE PARSING
# =============================================================================

def extract_phenotypes(df, col="Phenotype_day90_AllCategories"):
    records = []
    for _, row in df.iterrows():
        val = str(row[col])
        if val in ("", "nan", "None"):
            continue

        for cat in val.split(";"):
            cat = cat.strip()
            if cat and cat != "nan":
                records.append({"Family": row["Family"], "category": cat})

    return pd.DataFrame(records)

# =============================================================================
# FIGURE 1 — DOSE RESPONSE
# =============================================================================

def generate_fig1(dose_df):
    x = dose_df["EMS_Concentration"].values
    y = dose_df["Seedling_Survival_Mean"].values

    def ll4(x, c, d, e, b):
        return c + (d - c) / (1 + np.exp(b * (np.log(np.maximum(x, 1e-10)) - np.log(e))))

    popt, _ = curve_fit(ll4, x, y, maxfev=10000)

    fig = plt.figure(figsize=(6, 4))
    ax = fig.add_subplot(111)

    xx = np.linspace(min(x), max(x), 200)
    ax.scatter(x, y, color=COLOR["orange"])
    ax.plot(xx, ll4(xx, *popt), color=COLOR["blue"])

    ax.set_title("EMS Dose–Response")
    ax.set_xlabel("EMS Concentration")
    ax.set_ylabel("Survival Rate")

    fig.savefig(FIG_DIR / "Fig1_DoseResponse.pdf", bbox_inches="tight")
    plt.close(fig)

# =============================================================================
# FIGURE 3 — PHENOTYPE FREQUENCY
# =============================================================================

def generate_fig3(m2):
    pdf = extract_phenotypes(m2)

    gf = pdf.groupby("category").size().reset_index(name="n")
    gf["freq"] = gf["n"] / len(m2)

    fig = plt.figure(figsize=(7, 4))
    ax = fig.add_subplot(111)

    gf = gf.sort_values("freq", ascending=True)

    ax.barh(gf["category"], gf["freq"], color=COLOR["green"])
    ax.set_title("Phenotype Spectrum")
    ax.set_xlabel("Frequency")

    fig.savefig(FIG_DIR / "Fig3_PhenotypeSpectrum.pdf", bbox_inches="tight")
    plt.close(fig)

    gf.to_csv(TABLE_DIR / "Fig3_PhenotypeFrequency.csv", index=False)

# =============================================================================
# FIGURE 4 — TRAIT RESPONSE
# =============================================================================

def generate_fig4(dose):
    traits = [c for c in dose.columns if "Mean" in c]

    fig = plt.figure(figsize=(8, 5))
    ax = fig.add_subplot(111)

    for t in traits[:5]:
        ax.plot(dose["EMS_Concentration"], dose[t], label=t)

    ax.set_title("Trait Response to EMS")
    ax.set_xlabel("EMS Concentration")
    ax.set_ylabel("Trait Value")
    ax.legend()

    fig.savefig(FIG_DIR / "Fig4_TraitResponse.pdf", bbox_inches="tight")
    plt.close(fig)

# =============================================================================
# MAIN PIPELINE
# =============================================================================

def main():
    data = load_data()

    generate_fig1(data["dose"])
    generate_fig3(data["m2"])
    generate_fig4(data["dose"])

    print("Pipeline completed successfully.")
    print(f"Outputs saved to: {OUTPUT_DIR}")

if __name__ == "__main__":
    main()
